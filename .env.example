# Offline Neural Facilitator (ONF) - example configuration
# =========================================================
# Copy to ".env" in the repo root and edit. Every value has a safe default, and
# the defaults keep ONF fully offline and on-device. Nothing is sent to the
# network unless you explicitly enable the hybrid-online engine below.

# --- Server ---------------------------------------------------------------
ONF_HOST=127.0.0.1
ONF_PORT=8000
# Used when returning audio file URLs to the browser.
ONF_PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated allowed CORS origins (the Vite dev server by default).
ONF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Foundry Local (offline engine) --------------------------------------
# Model aliases from the Foundry Local catalog (`foundry model ls`).
ONF_REFLEX_MODEL=qwen2.5-0.5b
ONF_REASON_MODEL=qwen2.5-1.5b
# Let the SDK auto-start the service and download the model on first use.
ONF_FOUNDRY_BOOTSTRAP=true
# Optional: pin an explicit OpenAI-compatible endpoint (normally auto-resolved
# by the SDK; only needed if you run the Foundry server manually).
# ONF_FOUNDRY_ENDPOINT=http://localhost:5273/v1
# ONF_FOUNDRY_API_KEY=not-needed

# --- Hybrid online engine (OPT-IN, privacy sensitive) --------------------
# When disabled (default) NOTHING leaves the device. Enable to route the more
# demanding "Deep Think" requests to a more powerful cloud model.
ONF_ONLINE_ENABLED=false
# Any OpenAI-compatible endpoint (OpenAI, Azure OpenAI, OpenRouter, ...).
# ONF_ONLINE_BASE_URL=https://api.openai.com/v1
# ONF_ONLINE_API_KEY=sk-...
ONF_ONLINE_MODEL=gpt-4o-mini
# Which requests go online: "reason" (Deep Think only), "all", or "off".
ONF_ONLINE_ROUTE=reason

# --- Optional on-device capabilities -------------------------------------
# Each requires the matching package from requirements-optional.txt; if the
# dependency is missing the feature auto-disables (the backend still boots).
ONF_ENABLE_WHISPER=true
ONF_WHISPER_MODEL=small
ONF_ENABLE_TTS=false
ONF_ENABLE_DIARIZATION=true
ONF_ENABLE_VISION=true
ONF_ENABLE_PROACTIVE_LOOP=true

# --- Storage paths --------------------------------------------------------
ONF_OUTPUT_DIR=outputs_v2
ONF_SESSIONS_DIR=sessions
ONF_CHROMA_DIR=./chroma_db
